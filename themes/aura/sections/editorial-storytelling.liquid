<section class="editorial-storytelling" data-section-id="{{ section.id }}">
  <div class="editorial-storytelling__inner">
    <div class="editorial-storytelling__text">
      <div class="editorial-storytelling__text-inner container" data-animate>
        {%- if section.settings.eyebrow != blank -%}
          <p class="editorial-label">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="editorial-storytelling__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="editorial-storytelling__body">{{ section.settings.text }}</p>
        {%- endif -%}

        {%- if section.settings.quote != blank -%}
          <blockquote class="editorial-storytelling__quote">
            <p>{{ section.settings.quote }}</p>
          </blockquote>
        {%- endif -%}

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link }}" class="editorial-cta">
            {{ section.settings.cta_text }}
            <span class="editorial-cta__line" aria-hidden="true"></span>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="editorial-storytelling__image" data-animate data-animate-fade>
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          class="editorial-storytelling__img"
        >
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .editorial-storytelling {
    padding: 6rem 0;
  }

  .editorial-storytelling__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  .editorial-storytelling__text {
    display: flex;
    align-items: center;
    background: var(--color-inverse-bg);
    color: var(--color-inverse-text);
  }

  .editorial-storytelling__text-inner {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .editorial-storytelling__text .editorial-label {
    color: rgba(250,249,247,0.5);
    margin-bottom: 1.5rem;
  }

  .editorial-storytelling__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-inverse-text);
    margin: 0 0 1.5rem;
  }

  .editorial-storytelling__body {
    font-size: 0.9rem;
    line-height: 1.9;
    color: rgba(250,249,247,0.6);
    max-width: 380px;
    margin-bottom: 2rem;
  }

  .editorial-storytelling__quote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 0 0 2rem;
  }

  .editorial-storytelling__quote p {
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    font-style: italic;
    color: rgba(250,249,247,0.8);
    line-height: 1.5;
    margin: 0;
  }

  .editorial-storytelling__text .editorial-cta {
    color: var(--color-inverse-text);
    border-color: rgba(250,249,247,0.3);
  }

  .editorial-storytelling__text .editorial-cta:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .editorial-storytelling__image {
    position: relative;
    overflow: hidden;
  }

  .editorial-storytelling__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .editorial-storytelling:hover .editorial-storytelling__img {
    transform: scale(1.02);
  }

  @media (max-width: 900px) {
    .editorial-storytelling__inner {
      grid-template-columns: 1fr;
    }
    .editorial-storytelling__image {
      min-height: 50vh;
    }
  }
</style>

{% schema %}
{
  "name": "Editorial Storytelling",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Editorial Storytelling",
      "settings": {
        "eyebrow": "Our Story",
        "heading": "Crafted for Those Who Notice",
        "text": "Every seam, every silhouette, every choice of fabric reflects a commitment to uncompromising quality. Aura is for those who understand that true luxury lies in the details.",
        "quote": "Elegance is not about being noticed — it is about being remembered."
      }
    }
  ]
}
{% endschema %}
