{%- liquid
  assign collection = section.settings.collection
  assign heading = section.settings.heading | default: collection.title | default: 'Featured'
  assign layout = section.settings.layout | default: 'grid'
  assign show_vendor = section.settings.show_vendor
-%}

<section class="editorial-collection" data-section-id="{{ section.id }}">
  <div class="editorial-collection__header container">
    <div class="editorial-collection__header-inner">
      <div class="editorial-collection__meta">
        <span class="editorial-label" data-animate>{{ section.settings.eyebrow_text | default: 'Collection' }}</span>
        <span class="editorial-rule" data-animate data-animate-line></span>
      </div>
      <h2 class="editorial-collection__title" data-animate>{{ heading }}</h2>
    </div>
  </div>

  {%- if layout == 'asymmetric' -%}
    <div class="editorial-collection__asymmetric">
      {%- assign products_list = collection.products | slice: 0, 5 -%}
      {%- for product in products_list -%}
        {%- assign is_large = forloop.index == 1 or forloop.index == 3 -%}
        <div class="editorial-collection__asym-item{% if is_large %} editorial-collection__asym-item--large{% endif %} stagger-{{ forloop.index }}" data-animate>
          <a href="{{ product.url }}" class="editorial-collection__card">
            <div class="editorial-collection__card-media">
              {%- if product.featured_media != blank -%}
                <img
                  src="{{ product.featured_media | image_url: width: 800 }}"
                  alt="{{ product.featured_media.alt | escape }}"
                  loading="{% if forloop.index == 1 %}eager{% else %}lazy{% endif %}"
                  class="editorial-collection__card-image"
                >
              {%- else -%}
                <div class="editorial-collection__card-placeholder"></div>
              {%- endif -%}
              <div class="editorial-collection__card-overlay">
                <span class="editorial-collection__card-label">View</span>
              </div>
            </div>
            <div class="editorial-collection__card-info">
              {%- if show_vendor and product.vendor != blank -%}
                <p class="editorial-collection__card-vendor">{{ product.vendor }}</p>
              {%- endif -%}
              <h3 class="editorial-collection__card-title">{{ product.title | escape }}</h3>
              <p class="editorial-collection__card-price">{{ product.price | money }}</p>
            </div>
          </a>
        </div>
      {%- else -%}
        {%- for i in (1..5) -%}
          {%- assign is_large = forloop.index == 1 or forloop.index == 3 -%}
          <div class="editorial-collection__asym-item{% if is_large %} editorial-collection__asym-item--large{% endif %}">
            <div class="editorial-collection__card-placeholder"></div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  {%- else -%}
    <div class="editorial-collection__grid container">
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <div class="editorial-product-card stagger-{{ forloop.index | modulo: 4 }}" data-animate>
          <a href="{{ product.url }}" class="editorial-product-card__link">
            <div class="editorial-product-card__media">
              {%- if product.featured_media != blank -%}
                <img
                  src="{{ product.featured_media | image_url: width: 600 }}"
                  alt="{{ product.featured_media.alt | escape }}"
                  loading="lazy"
                  class="editorial-product-card__image"
                >
              {%- else -%}
                <div class="editorial-product-card__placeholder"></div>
              {%- endif -%}
              <div class="editorial-product-card__hover-overlay">
                <span>Quick View</span>
              </div>
            </div>
            <div class="editorial-product-card__info">
              {%- if show_vendor and product.vendor != blank -%}
                <p class="editorial-product-card__vendor">{{ product.vendor }}</p>
              {%- endif -%}
              <h3 class="editorial-product-card__title">{{ product.title | escape }}</h3>
              <p class="editorial-product-card__price">{{ product.price | money }}</p>
            </div>
          </a>
        </div>
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="editorial-product-card" data-animate>
            <div class="editorial-product-card__placeholder"></div>
            <div class="editorial-product-card__info">
              <p class="editorial-product-card__vendor">Maison</p>
              <h3 class="editorial-product-card__title">Editorial Piece</h3>
              <p class="editorial-product-card__price">$350.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<style>
  .editorial-collection {
    padding: 5rem 0 6rem;
  }

  .editorial-collection__header {
    margin-bottom: 3rem;
  }

  .editorial-collection__header-inner {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .editorial-collection__meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .editorial-collection__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1;
  }

  /* Asymmetric Layout */
  .editorial-collection__asymmetric {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 300px;
    gap: 0;
  }

  .editorial-collection__asym-item {
    grid-column: span 4;
    border: 1px solid var(--color-border);
    border-collapse: collapse;
  }

  .editorial-collection__asym-item--large {
    grid-column: span 8;
  }

  .editorial-collection__card {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .editorial-collection__card-media {
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .editorial-collection__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .editorial-collection__card:hover .editorial-collection__card-image {
    transform: scale(1.04);
  }

  .editorial-collection__card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-secondary);
  }

  .editorial-collection__card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26,26,26,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .editorial-collection__card:hover .editorial-collection__card-overlay {
    opacity: 1;
  }

  .editorial-collection__card-label {
    font-family: var(--font-body-family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #ffffff;
    padding: 0.5rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.5);
  }

  .editorial-collection__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(transparent, rgba(26,26,26,0.7));
  }

  .editorial-collection__card-vendor {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.3rem;
  }

  .editorial-collection__card-title {
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    color: #ffffff;
    margin: 0 0 0.25rem;
  }

  .editorial-collection__card-price {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
    margin: 0;
  }

  /* Grid Layout */
  .editorial-collection__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .editorial-product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .editorial-product-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    background: var(--color-secondary);
    margin-bottom: 1rem;
  }

  .editorial-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .editorial-product-card:hover .editorial-product-card__image {
    transform: scale(1.04);
  }

  .editorial-product-card__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-secondary);
  }

  .editorial-product-card__hover-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(26,26,26,0.3);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .editorial-product-card:hover .editorial-product-card__hover-overlay {
    opacity: 1;
  }

  .editorial-product-card__hover-overlay span {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #ffffff;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(255,255,255,0.6);
  }

  .editorial-product-card__vendor {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.25rem;
  }

  .editorial-product-card__title {
    font-family: var(--font-heading-family);
    font-size: 1rem;
    font-weight: 400;
    font-style: italic;
    margin: 0 0 0.4rem;
    transition: color 0.2s;
  }

  .editorial-product-card:hover .editorial-product-card__title {
    color: var(--color-accent);
  }

  .editorial-product-card__price {
    font-size: 0.85rem;
    color: rgba(26,26,26,0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .editorial-collection__grid { grid-template-columns: repeat(3, 1fr); }
    .editorial-collection__asymmetric {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 280px;
    }
    .editorial-collection__asym-item { grid-column: span 1; }
    .editorial-collection__asym-item--large { grid-column: span 1; }
  }

  @media (max-width: 640px) {
    .editorial-collection__grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .editorial-collection__asymmetric { grid-template-columns: 1fr; grid-auto-rows: 250px; }
  }
</style>

{% schema %}
{
  "name": "Featured Collection — Editorial",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "default": "Collection",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "asymmetric", "label": "Asymmetric" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Show vendor"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection — Editorial",
      "settings": {
        "heading": "The Collection",
        "eyebrow_text": "New Arrivals",
        "layout": "grid",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
