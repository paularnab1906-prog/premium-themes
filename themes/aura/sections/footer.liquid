<footer class="editorial-footer">
  <div class="editorial-footer__inner container">
    <div class="editorial-footer__top">
      <div class="editorial-footer__brand">
        <a href="{{ routes.root_url }}" class="editorial-footer__logo">{{ shop.name }}</a>
        <p class="editorial-footer__tagline">{{ shop.description | default: 'Where timeless design meets contemporary vision.' }}</p>
        <div class="editorial-footer__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener">
              {% render 'icon-instagram' %}
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest_link != blank -%}
            <a href="{{ settings.social_pinterest_link }}" aria-label="Pinterest" target="_blank" rel="noopener">
              {% render 'icon-pinterest' %}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="editorial-footer__links">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' and block.settings.menu != blank -%}
            <div class="editorial-footer__column" {{ block.shopify_attributes }}>
              <h3 class="editorial-footer__heading">{{ block.settings.heading | default: block.settings.menu.title }}</h3>
              <ul class="editorial-footer__list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" class="editorial-footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="editorial-footer__bottom">
      <p class="editorial-footer__copyright">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
      <div class="editorial-footer__legal">
        <a href="{{ routes.privacy_policy_url }}">Privacy Policy</a>
        <a href="{{ routes.terms_of_service_url }}">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .editorial-footer {
    background: var(--color-secondary);
    border-top: 1px solid var(--color-border);
    padding: 5rem 0 2rem;
  }

  .editorial-footer__top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .editorial-footer__logo {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    text-decoration: none;
    display: block;
    margin-bottom: 0.75rem;
    transition: opacity 0.2s;
  }

  .editorial-footer__logo:hover { opacity: 0.6; }

  .editorial-footer__tagline {
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(26,26,26,0.4);
    max-width: 280px;
    margin: 0 0 1.5rem;
  }

  .editorial-footer__social {
    display: flex;
    gap: 1rem;
  }

  .editorial-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    color: rgba(26,26,26,0.4);
    transition: all 0.2s;
    text-decoration: none;
  }

  .editorial-footer__social a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .editorial-footer__links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 2rem;
  }

  .editorial-footer__heading {
    font-family: var(--font-body-family);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.4);
    margin: 0 0 1.25rem;
  }

  .editorial-footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .editorial-footer__link {
    font-size: 0.875rem;
    color: rgba(26,26,26,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .editorial-footer__link:hover {
    color: var(--color-text);
  }

  .editorial-footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .editorial-footer__copyright {
    font-size: 0.75rem;
    color: rgba(26,26,26,0.3);
    margin: 0;
  }

  .editorial-footer__legal {
    display: flex;
    gap: 2rem;
  }

  .editorial-footer__legal a {
    font-size: 0.75rem;
    color: rgba(26,26,26,0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .editorial-footer__legal a:hover {
    color: rgba(26,26,26,0.7);
  }

  @media (max-width: 768px) {
    .editorial-footer__top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .editorial-footer {
      padding: 3rem 0 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Footer — Editorial",
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer — Editorial"
    }
  ]
}
{% endschema %}
