<header class="editorial-header" data-section-id="{{ section.id }}">
  <div class="editorial-header__inner container">
    <nav class="editorial-header__nav editorial-header__nav--left" aria-label="Main navigation left">
      {%- for link in linklists[section.settings.menu_left].links limit: 3 -%}
        <a href="{{ link.url }}" class="editorial-header__nav-link{% if link.current %} is-active{% endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="editorial-header__center">
      <a href="{{ routes.root_url }}" class="editorial-header__logo" aria-label="{{ shop.name }}">
        {{ shop.name }}
      </a>
    </div>

    <nav class="editorial-header__nav editorial-header__nav--right" aria-label="Main navigation right">
      {%- for link in linklists[section.settings.menu_right].links limit: 3 -%}
        <a href="{{ link.url }}" class="editorial-header__nav-link{% if link.current %} is-active{% endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="editorial-header__actions">
      <button class="editorial-header__icon-btn" aria-label="Search">
        {% render 'icon-search' %}
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="editorial-header__icon-btn" aria-label="Account">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="editorial-header__icon-btn editorial-header__cart">
        {% render 'icon-cart' %}
        <span class="editorial-header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<style>
  .editorial-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
  }

  .editorial-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
    gap: 2rem;
  }

  .editorial-header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .editorial-header__nav--left {
    justify-content: flex-start;
  }

  .editorial-header__nav--right {
    justify-content: flex-end;
  }

  .editorial-header__nav-link {
    font-family: var(--font-body-family);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(26,26,26,0.6);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .editorial-header__nav-link:hover,
  .editorial-header__nav-link.is-active {
    color: var(--color-text);
  }

  .editorial-header__logo {
    font-family: var(--font-heading-family);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    text-decoration: none;
    text-align: center;
    transition: opacity 0.2s;
  }

  .editorial-header__logo:hover {
    opacity: 0.7;
  }

  .editorial-header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .editorial-header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: rgba(26,26,26,0.5);
    transition: color 0.2s;
    position: relative;
    text-decoration: none;
  }

  .editorial-header__icon-btn:hover {
    color: var(--color-text);
  }

  .editorial-header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 16px;
    height: 16px;
    background: var(--color-accent);
    color: #ffffff;
    font-size: 0.6rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .editorial-header__nav {
      display: none;
    }
    .editorial-header__inner {
      grid-template-columns: auto 1fr auto;
    }
    .editorial-header__logo {
      font-size: 1.25rem;
    }
  }
</style>

{% schema %}
{
  "name": "Header — Editorial",
  "settings": [
    {
      "type": "linklist",
      "id": "menu_left",
      "default": "main-menu",
      "label": "Left Menu"
    },
    {
      "type": "linklist",
      "id": "menu_right",
      "default": "main-menu",
      "label": "Right Menu"
    }
  ],
  "presets": [
    {
      "name": "Header — Editorial"
    }
  ]
}
{% endschema %}
