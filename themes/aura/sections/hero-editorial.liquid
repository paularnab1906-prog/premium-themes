{%- liquid
  assign layout = section.settings.layout | default: 'standard'
  assign image = section.settings.image
  assign image_position = section.settings.image_position | default: 'right'
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
-%}

<section class="editorial-hero editorial-hero--{{ layout }}{% if image != blank %} editorial-hero--has-image{% endif %}" data-section-id="{{ section.id }}">

  {%- if image != blank -%}
    <div class="editorial-hero__image-wrap editorial-hero__image-wrap--{{ image_position }}">
      <img
        src="{{ image | image_url: width: 1200 }}"
        alt="{{ image.alt | escape }}"
        class="editorial-hero__image"
        loading="eager"
        fetchpriority="high"
      >
    </div>
  {%- endif -%}

  <div class="editorial-hero__content editorial-hero__content--{{ image_position }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="editorial-label editorial-hero__eyebrow" data-animate>{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if heading != blank -%}
      <h1 class="editorial-hero__heading" data-animate data-animate-fade>
        {{ heading | newline_to_br }}
      </h1>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="editorial-hero__subheading" data-animate data-animate-fade>{{ subheading }}</p>
    {%- endif -%}

    {%- if cta_text != blank and cta_link != blank -%}
      <div class="editorial-hero__cta" data-animate>
        <a href="{{ cta_link }}" class="editorial-cta">
          {{ cta_text }}
          <span class="editorial-cta__line" aria-hidden="true"></span>
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.secondary_text != blank -%}
      <p class="editorial-hero__secondary" data-animate>{{ section.settings.secondary_text }}</p>
    {%- endif -%}
  </div>
</section>

<style>
  .editorial-hero {
    position: relative;
    display: grid;
    min-height: 80vh;
    align-items: center;
    overflow: hidden;
  }

  /* Full-bleed layout */
  .editorial-hero--full {
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .editorial-hero--standard {
    grid-template-columns: 1fr 1fr;
    min-height: 70vh;
  }

  /* With image */
  .editorial-hero--has-image.editorial-hero--left .editorial-hero__image-wrap {
    order: -1;
  }

  .editorial-hero__image-wrap {
    position: relative;
    overflow: hidden;
    height: 100%;
    min-height: 50vh;
  }

  .editorial-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .editorial-hero:hover .editorial-hero__image {
    transform: scale(1.02);
  }

  .editorial-hero__content {
    padding: clamp(3rem, 8vw, 8rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .editorial-hero__content--left {
    padding-left: clamp(2rem, 6vw, 6rem);
  }

  .editorial-hero__content--right {
    padding-right: clamp(2rem, 6vw, 6rem);
  }

  .editorial-hero__eyebrow {
    margin-bottom: 1.5rem;
  }

  .editorial-hero__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }

  .editorial-hero__subheading {
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(26, 26, 26, 0.6);
    max-width: 400px;
    margin: 0 0 2rem;
  }

  .editorial-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body-family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--color-text);
    transition: color 0.2s, border-color 0.2s;
  }

  .editorial-cta:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .editorial-cta__line {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: currentColor;
    transition: width 0.3s ease;
  }

  .editorial-cta:hover .editorial-cta__line {
    width: 40px;
  }

  .editorial-hero__secondary {
    font-size: 0.75rem;
    color: rgba(26,26,26,0.4);
    margin-top: 1.5rem;
    margin-bottom: 0;
    letter-spacing: 0.05em;
  }

  @media (max-width: 900px) {
    .editorial-hero--full,
    .editorial-hero--standard {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .editorial-hero__image-wrap {
      min-height: 50vh;
    }
    .editorial-hero__content--left,
    .editorial-hero__content--right {
      padding: 3rem var(--gutter);
    }
  }
</style>

{% schema %}
{
  "name": "Hero — Editorial",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "full", "label": "Full Bleed" }
      ],
      "default": "standard"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Elegance"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary Text (Date / Issue)"
    }
  ],
  "presets": [
    {
      "name": "Hero — Editorial",
      "settings": {
        "layout": "standard",
        "image_position": "right",
        "eyebrow": "Spring 2026 Collection",
        "heading": "The Art\nof Elegance",
        "subheading": "Where timeless design meets contemporary vision. Discover a new chapter in luxury fashion.",
        "cta_text": "Explore Collection",
        "cta_link": "/collections/all",
        "secondary_text": "No. 47 — Spring / Summer"
      }
    }
  ]
}
{% endschema %}
