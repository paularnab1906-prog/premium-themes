<div class="announcement-bar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
  {%- for block in section.blocks -%}
    <div class="announcement-bar__item" {{ block.shopify_attributes }}>
      {%- if block.settings.text != blank -%}
        <p class="announcement-bar__message">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
          {%- else -%}
            {{ block.settings.text | escape }}
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

<style>
  .announcement-bar {
    background-color: var(--color-secondary);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .announcement-bar__message {
    margin: 0;
    padding: 0.75rem 2rem;
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    text-align: center;
  }

  .announcement-bar__message a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .announcement-bar__message a:hover {
    color: var(--color-accent);
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders over $150",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Complimentary shipping on all orders over $150"
          }
        }
      ]
    }
  ]
}
{% endschema %}
{% endschema %}
