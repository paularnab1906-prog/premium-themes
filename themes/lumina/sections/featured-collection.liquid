{%- liquid
  assign collection = section.settings.collection
  assign heading = section.settings.heading | default: collection.title | default: 'Featured Collection'
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns | default: 4
  assign show_vendor = section.settings.show_vendor
  assign show_price = section.settings.show_price
-%}

<section class="featured-collection" data-section-id="{{ section.id }}">
  <div class="featured-collection__header" data-animate>
    {%- if heading != blank -%}
      <h2 class="featured-collection__title">{{ heading }}</h2>
    {%- endif -%}
    {%- if subheading != blank -%}
      <p class="featured-collection__subheading">{{ subheading }}</p>
    {%- endif -%}
  </div>

  <div
    class="featured-collection__grid"
    style="--columns: {{ columns }};"
    data-animate
  >
    {%- for product in collection.products limit: section.settings.products_to_show -%}
      <div class="featured-collection__item stagger-{{ forloop.index | modulo: 5 }}">
        {% render 'product-card', product: product, show_vendor: show_vendor, show_price: show_price %}
      </div>
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="product-card product-card--placeholder" data-animate>
          <div class="product-card__image-wrap">
            <div class="product-card__image-placeholder"></div>
          </div>
          <div class="product-card__info">
            <p class="product-card__vendor">Sample Brand</p>
            <h3 class="product-card__title">Product Name</h3>
            <p class="product-card__price">$149.00</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_text != blank -%}
    <div class="featured-collection__cta" data-animate>
      <a href="{{ section.settings.cta_link | default: collection.url }}" class="btn-text">
        {{ section.settings.cta_text }}
        <span class="btn-text__arrow">{% render 'icon-arrow-right' %}</span>
      </a>
    </div>
  {%- endif -%}
</section>

<style>
  .featured-collection {
    padding: 6rem 3rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .featured-collection__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .featured-collection__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #ffffff;
  }

  .featured-collection__subheading {
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
    max-width: 500px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns, 4), 1fr);
    gap: 2rem;
  }

  .featured-collection__cta {
    margin-top: 3rem;
    text-align: center;
  }

  .btn-text {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .btn-text:hover {
    gap: 0.75rem;
  }

  .btn-text__arrow {
    display: flex;
  }

  @media (max-width: 1024px) {
    .featured-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .featured-collection {
      padding: 4rem 1.5rem;
    }
    .featured-collection__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "default": 4,
      "label": "Columns"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "default": true,
      "label": "Show price"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "heading": "Our Collection",
        "subheading": "Curated pieces that define the season.",
        "products_to_show": 4,
        "columns": 4
      }
    }
  ]
}
{% endschema %}
{% endschema %}
