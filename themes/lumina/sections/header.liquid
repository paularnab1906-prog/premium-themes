<header class="header" data-section-id="{{ section.id }}">
  <div class="header__inner">
    <div class="header__left">
      <button class="header__menu-toggle" aria-label="Open menu" aria-expanded="false">
        <span class="header__menu-icon"></span>
      </button>

      <nav class="header__nav" aria-label="Main navigation">
        {%- for link in section.settings.menu.links -%}
          <a
            href="{{ link.url }}"
            class="header__nav-link{% if link.current %} is-active{% endif %}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>

    <div class="header__center">
      <a href="{{ routes.root_url }}" class="header__logo" aria-label="{{ shop.name }}">
        <span class="header__logo-text">{{ shop.name }}</span>
      </a>
    </div>

    <div class="header__right">
      <button class="header__icon-btn" aria-label="Search">
        {% render 'icon-search' %}
      </button>

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon-btn header__cart-btn" aria-label="Cart">
        {% render 'icon-cart' %}
        <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {%- if settings.search_enabled -%}
    <div class="header__search" aria-hidden="true">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
        <input
          type="search"
          name="q"
          class="search-form__input"
          placeholder="Search..."
          autocomplete="off"
        >
        <button type="submit" class="search-form__submit">
          {% render 'icon-search' %}
        </button>
      </form>
    </div>
  {%- endif -%}
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: transparent;
    transition: background-color 0.4s ease, backdrop-filter 0.4s ease;
  }

  .header.is-scrolled {
    background-color: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 1.5rem 3rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .header__menu-toggle {
    display: none;
    width: 24px;
    height: 14px;
    position: relative;
    cursor: pointer;
  }

  .header__menu-icon,
  .header__menu-icon::before,
  .header__menu-icon::after {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-text);
    transition: all 0.3s ease;
    position: absolute;
  }

  .header__menu-icon::before,
  .header__menu-icon::after {
    content: '';
  }

  .header__menu-icon::before { top: 0; }
  .header__menu-icon::after { bottom: 0; }
  .header__menu-icon { top: 50%; transform: translateY(-50%); }

  .header__nav {
    display: flex;
    gap: 2rem;
  }

  .header__nav-link {
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  .header__nav-link:hover,
  .header__nav-link.is-active {
    color: #ffffff;
  }

  .header__nav-link:hover::after,
  .header__nav-link.is-active::after {
    width: 100%;
  }

  .header__center {
    text-align: center;
  }

  .header__logo {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #ffffff;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .header__logo:hover {
    opacity: 0.8;
  }

  .header__right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    justify-content: flex-end;
  }

  .header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: rgba(255,255,255,0.8);
    transition: color 0.2s;
    position: relative;
  }

  .header__icon-btn:hover {
    color: #ffffff;
  }

  .header__cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    min-width: 16px;
    height: 16px;
    background: var(--color-accent);
    color: var(--color-background);
    font-size: 0.625rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
  }

  @media (max-width: 768px) {
    .header__inner {
      padding: 1rem 1.5rem;
    }
    .header__nav {
      display: none;
    }
    .header__menu-toggle {
      display: flex;
    }
    .header__logo {
      font-size: 1.1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var header = document.querySelector('.header');
    if (!header) return;
    var lastScroll = 0;
    window.addEventListener('scroll', function() {
      var scroll = window.pageYOffset;
      if (scroll > 80) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
      lastScroll = scroll;
    }, { passive: true });
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
