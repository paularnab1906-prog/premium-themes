{%- liquid
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign text_alignment = section.settings.text_alignment | default: 'center'
  assign background = section.settings.background | default: 'dark'
-%}

<section class="rich-text-section rich-text-section--{{ background }}">
  <div class="rich-text-section__inner" data-animate>
    {%- if heading != blank -%}
      <h2 class="rich-text-section__heading">{{ heading }}</h2>
    {%- endif -%}
    {%- if text != blank -%}
      <div class="rich-text-section__text">
        {{ text | newline_to_br }}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .rich-text-section {
    padding: 6rem 3rem;
  }

  .rich-text-section--dark {
    background-color: var(--color-background);
  }

  .rich-text-section--light {
    background-color: var(--color-secondary);
  }

  .rich-text-section__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .rich-text-section--left .rich-text-section__inner {
    text-align: left;
    margin: 0;
  }

  .rich-text-section__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0 0 1.5rem;
    line-height: 1.1;
  }

  .rich-text-section__text {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.6);
  }

  @media (max-width: 768px) {
    .rich-text-section {
      padding: 4rem 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Rich Text",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "settings": {
        "heading": "Designed for the Discerning",
        "text": "We believe that every brand deserves a storefront as remarkable as their products."
      }
    }
  ]
}
{% endschema %}
