{%- liquid
  assign video_url = section.settings.video_url
  assign poster = section.settings.poster
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign layout = section.settings.layout
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
-%}

<section class="video-banner video-banner--{{ layout }}" data-section-id="{{ section.id }}">
  <div class="video-banner__media">
    {%- if video_url != blank -%}
      <video
        class="video-banner__video"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="{{ poster | image_url: width: 1200 }}"
      >
        {%- if video_url.type == 'youtube' -%}
          <source src="https://www.youtube.com/embed/{{ video_url.id }}" type="video/youtube">
        {%- elsif video_url.type == 'vimeo' -%}
          <source src="https://player.vimeo.com/video/{{ video_url.id }}?background=1" type="video/vimeo">
        {%- else -%}
          <source src="{{ video_url }}" type="video/mp4">
        {%- endif -%}
      </video>
    {%- elsif poster != blank -%}
      <img
        src="{{ poster | image_url: width: 1200 }}"
        alt="{{ poster.alt | escape }}"
        class="video-banner__poster"
        loading="lazy"
      >
    {%- endif -%}

    <div class="video-banner__overlay"></div>
  </div>

  <div class="video-banner__content" data-animate>
    {%- if heading != blank -%}
      <h2 class="video-banner__heading">{{ heading }}</h2>
    {%- endif -%}
    {%- if text != blank -%}
      <p class="video-banner__text">{{ text }}</p>
    {%- endif -%}
    {%- if cta_text != blank and cta_link != blank -%}
      <a href="{{ cta_link }}" class="video-banner__cta btn btn--outline">
        {{ cta_text }}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  .video-banner {
    position: relative;
    overflow: hidden;
    min-height: 500px;
    display: flex;
    align-items: center;
  }

  .video-banner--large {
    min-height: 700px;
  }

  .video-banner__media {
    position: absolute;
    inset: 0;
  }

  .video-banner__video,
  .video-banner__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(10,10,10,0.8) 0%,
      rgba(10,10,10,0.4) 100%
    );
  }

  .video-banner__content {
    position: relative;
    z-index: 2;
    padding: 5rem 3rem;
    max-width: 700px;
  }

  .video-banner--right .video-banner__content {
    margin-left: auto;
  }

  .video-banner__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .video-banner__text {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
    margin: 0 0 2rem;
  }

  .video-banner__cta {
    display: inline-flex;
  }

  @media (max-width: 768px) {
    .video-banner {
      min-height: 400px;
    }
    .video-banner__content {
      padding: 3rem 1.5rem;
    }
    .video-banner--right .video-banner__content {
      margin-left: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Video Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster Image / Fallback"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "placeholder": "https://..."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "left", "label": "Text Left" },
        { "value": "right", "label": "Text Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "large",
      "label": "Large height"
    }
  ],
  "presets": [
    {
      "name": "Video Banner",
      "settings": {
        "heading": "The Art of Craftsmanship",
        "text": "Every piece tells a story. Discover our latest collection, where heritage meets modern design.",
        "cta_text": "Discover More",
        "cta_link": "/collections/all"
      }
    }
  ]
}
{% endschema %}
