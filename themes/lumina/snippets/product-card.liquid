{%- liquid
  assign product = product
  assign show_vendor = show_vendor | default: false
  assign show_price = show_price | default: true
  assign image_ratio = section.settings.image_ratio | default: 'portrait'

  assign featured_media = product.featured_media
  assign media = featured_media
  assign hover_image = product.images[1] | default: media

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign sold_out = false
  unless product.available
    assign sold_out = true
  endunless
-%}

<article class="product-card" data-animate data-animate-scale>
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">
    <div class="product-card__media">
      {%- if media != blank -%}
        <img
          src="{{ media | image_url: width: 600 }}"
          alt="{{ media.alt | escape }}"
          class="product-card__image"
          loading="lazy"
          width="600"
          height="{{ 600 | times: media.aspect_ratio | round }}"
        >
      {%- else -%}
        <div class="product-card__image-placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- if hover_image != blank and hover_image != media -%}
        <img
          src="{{ hover_image | image_url: width: 600 }}"
          alt="{{ hover_image.alt | escape }}"
          class="product-card__image product-card__image--hover"
          loading="lazy"
          width="600"
          height="{{ 600 | times: hover_image.aspect_ratio | round }}"
        >
      {%- endif -%}

      {%- if sold_out -%}
        <span class="product-card__badge product-card__badge--sold-out">Sold Out</span>
      {%- elsif on_sale -%}
        <span class="product-card__badge product-card__badge--sale">Sale</span>
      {%- endif -%}

      <div class="product-card__actions" aria-hidden="true">
        <button
          class="product-card__quick-add"
          data-product-id="{{ product.id }}"
          aria-label="Quick add to cart"
        >
          {% render 'icon-bag' %}
          <span>Quick Add</span>
        </button>
      </div>
    </div>

    <div class="product-card__info">
      {%- if show_vendor and product.vendor != blank -%}
        <p class="product-card__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h3 class="product-card__title">{{ product.title | escape }}</h3>

      {%- if show_price -%}
        <div class="product-card__price">
          {%- if on_sale -%}
            <span class="product-card__price-compare">{{ product.compare_at_price | money }}</span>
            <span class="product-card__price-sale">{{ product.price | money }}</span>
          {%- else -%}
            <span class="product-card__price-regular">{{ product.price | money }}</span>
          {%- endif -%}

          {%- if product.price_varies == false and product.compare_at_price > product.price -%}
            <span class="visually-hidden">{{ 'products.product.price.sale_price' | t }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </a>
</article>

<style>
  .product-card {
    position: relative;
  }

  .product-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-card__media {
    position: relative;
    overflow: hidden;
    background-color: var(--color-secondary);
    aspect-ratio: 3 / 4;
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  .product-card__image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .product-card:hover .product-card__image:not(.product-card__image--hover) {
    opacity: 0;
    transform: scale(1.03);
  }

  .product-card:hover .product-card__image--hover {
    opacity: 1;
    transform: scale(1);
  }

  .product-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card__image-placeholder .placeholder-svg {
    width: 60%;
    height: 60%;
    fill: var(--color-border);
  }

  .product-card__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    z-index: 2;
  }

  .product-card__badge--sold-out {
    background-color: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
    backdrop-filter: blur(4px);
  }

  .product-card__badge--sale {
    background-color: var(--color-accent);
    color: var(--color-background);
  }

  .product-card__actions {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .product-card__actions {
    transform: translateY(0);
  }

  .product-card__quick-add {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem;
    background-color: rgba(255,255,255,0.95);
    color: var(--color-background);
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s;
    border: none;
  }

  .product-card__quick-add:hover {
    background-color: #ffffff;
  }

  .product-card__quick-add svg {
    width: 16px;
    height: 16px;
  }

  .product-card__info {
    padding: 1rem 0 0;
  }

  .product-card__vendor {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.4rem;
  }

  .product-card__title {
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    transition: color 0.2s;
  }

  .product-card:hover .product-card__title {
    color: var(--color-accent);
  }

  .product-card__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .product-card__price-compare {
    text-decoration: line-through;
    color: rgba(255,255,255,0.35);
    font-size: 0.8rem;
  }

  .product-card__price-sale {
    color: var(--color-accent);
    font-weight: 600;
  }

  .product-card__price-regular {
    color: rgba(255,255,255,0.7);
  }
</style>
