{%- liquid
  assign collection = section.settings.collection
  assign heading = section.settings.heading | default: collection.title | default: 'Featured'
  assign columns = section.settings.columns | default: 3
  assign show_vendor = section.settings.show_vendor
-%}

<section class="featured-3d-collection" data-section-id="{{ section.id }}">
  <div class="featured-3d-collection__header" data-animate>
    <div class="featured-3d-collection__badge">
      <span class="badge-dot"></span>
      {{ section.settings.badge_text | default: '3D Ready' }}
    </div>
    <h2 class="featured-3d-collection__title">{{ heading }}</h2>
    {%- if section.settings.subheading -%}
      <p class="featured-3d-collection__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="featured-3d-collection__grid" style="--columns: {{ columns }};">
    {%- for product in collection.products limit: section.settings.products_to_show -%}
      {%- assign has_3d = false -%}
      {%- for media in product.media -%}
        {%- if media.media_type == 'model' -%}
          {%- assign has_3d = true -%}
        {%- endif -%}
      {%- endfor -%}

      <div class="product-3d-card stagger-{{ forloop.index | modulo: 5 }}" data-animate>
        <a href="{{ product.url }}" class="product-3d-card__link">
          <div class="product-3d-card__media glass">
            {%- assign featured = product.featured_media -%}
            {%- if featured != blank -%}
              <img
                src="{{ featured | image_url: width: 600 }}"
                alt="{{ featured.alt | escape }}"
                class="product-3d-card__image"
                loading="lazy"
              >
            {%- else -%}
              <div class="product-3d-card__placeholder"></div>
            {%- endif -%}

            {%- if has_3d -%}
              <div class="product-3d-card__3d-badge" title="3D model available">
                {% render 'icon-3d' %}
                <span>3D</span>
              </div>
            {%- endif -%}

            <div class="product-3d-card__overlay">
              <span class="product-3d-card__view-btn">
                {% render 'icon-eye' %}
                Quick View
              </span>
            </div>
          </div>

          <div class="product-3d-card__info">
            {%- if show_vendor and product.vendor != blank -%}
              <p class="product-3d-card__vendor">{{ product.vendor }}</p>
            {%- endif -%}
            <h3 class="product-3d-card__title">{{ product.title | escape }}</h3>
            <div class="product-3d-card__price">
              <span class="product-3d-card__price-current">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="product-3d-card__price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      </div>
    {%- else -%}
      {%- for i in (1..3) -%}
        <div class="product-3d-card" data-animate>
          <div class="product-3d-card__media glass">
            <div class="product-3d-card__placeholder"></div>
          </div>
          <div class="product-3d-card__info">
            <p class="product-3d-card__vendor">Sample Brand</p>
            <h3 class="product-3d-card__title">3D Product Name</h3>
            <p class="product-3d-card__price">$199.00</p>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .featured-3d-collection {
    padding: 6rem 3rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .featured-3d-collection__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .featured-3d-collection__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: var(--color-glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-secondary);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent-secondary);
    box-shadow: 0 0 8px var(--color-accent-secondary);
  }

  .featured-3d-collection__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .featured-3d-collection__subheading {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
    max-width: 480px;
    margin-inline: auto;
  }

  .featured-3d-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns, 3), 1fr);
    gap: 1.5rem;
  }

  .product-3d-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-3d-card__media {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 1 / 1.2;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-3d-card:hover .product-3d-card__media {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 20px 60px rgba(124, 58, 237, 0.2);
  }

  .product-3d-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-3d-card:hover .product-3d-card__image {
    transform: scale(1.05);
  }

  .product-3d-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-secondary) 0%, rgba(124, 58, 237, 0.1) 100%);
  }

  .product-3d-card__3d-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.6rem;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-secondary) 100%);
    border-radius: 1rem;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: #ffffff;
    text-transform: uppercase;
    z-index: 2;
  }

  .product-3d-card__3d-badge svg {
    width: 12px;
    height: 12px;
  }

  .product-3d-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 20, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .product-3d-card:hover .product-3d-card__overlay {
    opacity: 1;
  }

  .product-3d-card__view-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-glass);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #ffffff;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }

  .product-3d-card:hover .product-3d-card__view-btn {
    transform: translateY(0);
  }

  .product-3d-card__info {
    padding: 1rem 0.25rem 0;
  }

  .product-3d-card__vendor {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-secondary);
    margin: 0 0 0.3rem;
  }

  .product-3d-card__title {
    font-family: var(--font-body-family);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    transition: color 0.2s;
  }

  .product-3d-card:hover .product-3d-card__title {
    color: var(--color-accent);
  }

  .product-3d-card__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .product-3d-card__price-compare {
    text-decoration: line-through;
    color: rgba(255,255,255,0.3);
    font-size: 0.8rem;
  }

  .product-3d-card__price-current {
    color: rgba(255,255,255,0.9);
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .featured-3d-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .featured-3d-collection {
      padding: 4rem 1.5rem;
    }
    .featured-3d-collection__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collection — 3D",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "badge_text",
      "default": "3D Ready",
      "label": "Badge Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "default": 6,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "default": 3,
      "label": "Columns"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Show vendor"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection — 3D",
      "settings": {
        "heading": "Explore in 3D",
        "subheading": "Interactive product models you can rotate and inspect from every angle.",
        "products_to_show": 6,
        "columns": 3
      }
    }
  ]
}
{% endschema %}
