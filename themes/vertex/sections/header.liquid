<header class="header-3d" data-section-id="{{ section.id }}">
  <div class="header-3d__inner glass">
    <div class="header-3d__left">
      <button class="header-3d__menu-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <nav class="header-3d__nav">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="header-3d__nav-link{% if link.current %} is-active{% endif %}">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>

    <div class="header-3d__center">
      <a href="{{ routes.root_url }}" class="header-3d__logo">{{ shop.name }}</a>
    </div>

    <div class="header-3d__right">
      <button class="header-3d__icon-btn" aria-label="Search">
        {% render 'icon-search' %}
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header-3d__icon-btn" aria-label="Account">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="header-3d__icon-btn header-3d__cart">
        {% render 'icon-cart' %}
        <span class="header-3d__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<style>
  .header-3d {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 2rem;
  }

  .header-3d__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0.875rem 2rem;
    border-radius: 1rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .header-3d__left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header-3d__menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    padding: 4px;
  }

  .header-3d__menu-toggle span {
    display: block;
    width: 20px;
    height: 1px;
    background: var(--color-text);
  }

  .header-3d__nav {
    display: flex;
    gap: 1.75rem;
  }

  .header-3d__nav-link {
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .header-3d__nav-link:hover,
  .header-3d__nav-link.is-active {
    color: var(--color-accent-secondary);
  }

  .header-3d__center {
    text-align: center;
  }

  .header-3d__logo {
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #ffffff, rgba(255,255,255,0.7));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .header-3d__right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .header-3d__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 0.5rem;
    color: rgba(255,255,255,0.6);
    transition: all 0.2s;
    position: relative;
  }

  .header-3d__icon-btn:hover {
    color: #ffffff;
    background: rgba(255,255,255,0.08);
  }

  .header-3d__cart-count {
    position: absolute;
    top: -2px;
    right: -2px;
    min-width: 16px;
    height: 16px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary));
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .header-3d {
      padding: 0.75rem 1rem;
    }
    .header-3d__inner {
      padding: 0.75rem 1rem;
      border-radius: 0.75rem;
    }
    .header-3d__nav {
      display: none;
    }
    .header-3d__menu-toggle {
      display: flex;
    }
    .header-3d__logo {
      font-size: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Header — 3D",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ],
  "presets": [
    {
      "name": "Header — 3D"
    }
  ]
}
{% endschema %}
