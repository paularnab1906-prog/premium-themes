{%- liquid
  assign heading = section.settings.heading
  assign text = section.settings.text
  assign layout = section.settings.layout | default: 'center'
  assign image = section.settings.image
  assign image_position = section.settings.image_position | default: 'right'
-%}

<section class="immersive-storytelling" data-section-id="{{ section.id }}">
  <div class="immersive-storytelling__inner immersive-storytelling__inner--{{ layout }}">
    <div class="immersive-storytelling__content" data-animate data-animate-fade>
      {%- if section.settings.eyebrow != blank -%}
        <p class="immersive-storytelling__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="immersive-storytelling__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if text != blank -%}
        <p class="immersive-storytelling__text">{{ text }}</p>
      {%- endif -%}

      {%- if section.settings.stat_items != blank -%}
        <div class="immersive-storytelling__stats">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="stat-item glass" {{ block.shopify_attributes }}>
                <span class="stat-item__value">{{ block.settings.value }}</span>
                <span class="stat-item__label">{{ block.settings.label }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="immersive-storytelling__cta">
          {{ section.settings.cta_text }}
          {% render 'icon-arrow-right' %}
        </a>
      {%- endif -%}
    </div>

    {%- if image != blank -%}
      <div class="immersive-storytelling__visual" data-animate data-animate-3d>
        <div class="immersive-storytelling__image-wrap glass">
          <img
            src="{{ image | image_url: width: 800 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
            class="immersive-storytelling__image"
          >
          <div class="immersive-storytelling__glow"></div>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .immersive-storytelling {
    padding: 6rem 3rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .immersive-storytelling__inner {
    display: grid;
    gap: 4rem;
    align-items: center;
  }

  .immersive-storytelling__inner--center {
    text-align: center;
    justify-content: center;
  }

  .immersive-storytelling__inner--split {
    grid-template-columns: 1fr 1fr;
  }

  .immersive-storytelling__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-secondary);
    margin: 0 0 1.25rem;
  }

  .immersive-storytelling__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 1.25rem;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.75) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .immersive-storytelling__text {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.55);
    margin: 0 0 2rem;
    max-width: 480px;
  }

  .immersive-storytelling__inner--center .immersive-storytelling__text {
    margin-inline: auto;
  }

  .immersive-storytelling__stats {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .immersive-storytelling__inner--center .immersive-storytelling__stats {
    justify-content: center;
  }

  .stat-item {
    padding: 1rem 1.5rem;
    border-radius: 1rem;
    text-align: center;
    min-width: 100px;
  }

  .stat-item__value {
    display: block;
    font-family: var(--font-heading-family);
    font-size: 1.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-item__label {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-top: 0.25rem;
  }

  .immersive-storytelling__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .immersive-storytelling__cta:hover {
    gap: 0.75rem;
  }

  .immersive-storytelling__visual {
    position: relative;
  }

  .immersive-storytelling__image-wrap {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .immersive-storytelling__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .immersive-storytelling__image-wrap:hover .immersive-storytelling__image {
    transform: scale(1.03);
  }

  .immersive-storytelling__glow {
    position: absolute;
    bottom: -20%;
    left: -20%;
    width: 60%;
    height: 60%;
    background: radial-gradient(ellipse, var(--color-accent) 0%, transparent 70%);
    opacity: 0.3;
    filter: blur(40px);
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .immersive-storytelling__inner--split {
      grid-template-columns: 1fr;
    }
    .immersive-storytelling {
      padding: 4rem 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Immersive Storytelling",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "split", "label": "Split (Content + Image)" }
      ],
      "default": "split"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value" },
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Immersive Storytelling",
      "settings": {
        "eyebrow": "Why Vertex",
        "heading": "Products That Leap Off The Screen",
        "text": "Traditional product photos can't capture the full story. Vertex gives your customers a real sense of scale, texture, and form — reducing returns and boosting conversion."
      }
    }
  ]
}
{% endschema %}
