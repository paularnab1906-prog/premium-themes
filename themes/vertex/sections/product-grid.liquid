<div class="product-grid-3d" style="--columns: {{ section.settings.columns | default: 3 }};" data-section-id="{{ section.id }}">
  {%- for product in collection.products limit: section.settings.products_to_show -%}
    <div class="product-grid-3d__item" data-animate>
      <a href="{{ product.url }}" class="product-grid-3d__card glass">
        {%- if product.featured_media != blank -%}
          <img
            src="{{ product.featured_media | image_url: width: 600 }}"
            alt="{{ product.featured_media.alt | escape }}"
            class="product-grid-3d__image"
            loading="lazy"
          >
        {%- else -%}
          <div class="product-grid-3d__placeholder"></div>
        {%- endif -%}
        <div class="product-grid-3d__info">
          <p class="product-grid-3d__vendor">{{ product.vendor }}</p>
          <h3 class="product-grid-3d__title">{{ product.title | escape }}</h3>
          <p class="product-grid-3d__price">{{ product.price | money }}</p>
        </div>
      </a>
    </div>
  {%- else -%}
    {%- for i in (1..6) -%}
      <div class="product-grid-3d__card glass" data-animate>
        <div class="product-grid-3d__placeholder"></div>
        <div class="product-grid-3d__info">
          <p class="product-grid-3d__vendor">Sample Brand</p>
          <h3 class="product-grid-3d__title">Product Name</h3>
          <p class="product-grid-3d__price">$199.00</p>
        </div>
      </div>
    {%- endfor -%}
  {%- endfor -%}
</div>

<style>
  .product-grid-3d {
    display: grid;
    grid-template-columns: repeat(var(--columns, 3), 1fr);
    gap: 1.5rem;
    padding: 2rem 3rem 6rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .product-grid-3d__card {
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.4s ease;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .product-grid-3d__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 20px 60px rgba(124, 58, 237, 0.2);
  }

  .product-grid-3d__image,
  .product-grid-3d__placeholder {
    aspect-ratio: 1 / 1.2;
    width: 100%;
    object-fit: cover;
    background: linear-gradient(135deg, var(--color-secondary), rgba(124,58,237,0.1));
    display: block;
  }

  .product-grid-3d__info {
    padding: 1rem;
  }

  .product-grid-3d__vendor {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-secondary);
    margin: 0 0 0.3rem;
  }

  .product-grid-3d__title {
    font-size: 0.875rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .product-grid-3d__price {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .product-grid-3d { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .product-grid-3d { padding: 1.5rem 1.5rem 4rem; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  }
</style>

{% schema %}
{
  "name": "Product Grid — 3D",
  "settings": [
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "default": 3,
      "label": "Columns"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 48,
      "default": 12,
      "label": "Products per page"
    }
  ]
}
{% endschema %}
